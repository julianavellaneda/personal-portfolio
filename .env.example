# EmailJS configuration for the contact form.
# Sign up at https://www.emailjs.com/, create a service + template, then paste IDs below.
# The public key is safe to ship in client code, but enable the domain allowlist
# in the EmailJS dashboard so it can't be abused from other origins.
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
